# FileShare environment variables
# Copy this file to `.env` and fill in your secrets. The `.env` file is git-ignored.

# VirusTotal API key (free tier: https://www.virustotal.com/gui/my-apikey).
# If left blank or absent, the application falls back to an emulated scanner
# that returns deterministic random verdicts and flags the result as IsEmulated=true,
# so academic demos can run without an API key.
VIRUSTOTAL_API_KEY=
