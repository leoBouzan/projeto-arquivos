{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=App_Data/fileshare.db"
  },
  "Storage": {
    "RootPath": "App_Data/storage"
  },
  "Security": {
    "DeviceCookieName": "fs_device",
    "RequireHttpsCookies": false,
    "MaxUploadSizeBytes": 104857600,
    "AllowedOrigins": [
      "http://localhost:4200"
    ],
    "RateLimiting": {
      "GlobalIp": {
        "PermitLimit": 300,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "PublicRead": {
        "PermitLimit": 60,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "PublicDownload": {
        "PermitLimit": 20,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Upload": {
        "PermitLimit": 10,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      "Delete": {
        "PermitLimit": 10,
        "WindowSeconds": 300,
        "QueueLimit": 0
      }
    }
  }
}
