{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Persistence": {
    "Provider": "Sqlite",
    "ConnectionString": "Data Source=App_Data/fileshare.db"
  },
  "Storage": {
    "RootPath": "App_Data/storage"
  },
  "Cleanup": {
    "IntervalSeconds": 30,
    "BatchSize": 100
  }
}
